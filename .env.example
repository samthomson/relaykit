# JWT secret for session tokens (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here

# Public domain this RelayKit instance is served on (REQUIRED for prod SSL).
# Traefik requests a Let's Encrypt cert for this host. e.g. rkit.example.com
RELAYKIT_HOST=

# Deploy script (optional): user@host or SSH alias, and repo path on server
DEPLOY_HOST=root@1.2.3.4
DEPLOY_PATH=/root/relaykit-proto
